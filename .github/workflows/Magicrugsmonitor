name: 🔍 Magicrugs Traffic Monitor & Auto-Block

on:
  schedule:
    # Run every 6 hours
    - cron: '0 */6 * * *'
  
  # Allow manual trigger from Actions tab
  workflow_dispatch:
    inputs:
      days:
        description: 'Number of days to analyze'
        required: false
        default: '2'

jobs:
  monitor:
    runs-on: ubuntu-latest
    
    steps:
    - name: 📥 Checkout repository
      uses: actions/checkout@v4
      with:
        fetch-depth: 1

    - name: 🔑 Configure SSH
      env:
        SSH_PRIVATE_KEY: ${{ secrets.EC2_SSH_KEY }}
        EC2_HOST: ${{ secrets.EC2_HOST }}
        EC2_USER: ${{ secrets.EC2_USER }}
      run: |
        mkdir -p ~/.ssh
        echo "$SSH_PRIVATE_KEY" > ~/.ssh/id_rsa
        chmod 600 ~/.ssh/id_rsa
        ssh-keyscan -H "$EC2_HOST" >> ~/.ssh/known_hosts 2>/dev/null || true

    - name: 🚀 Run monitor script on EC2
      env:
        EC2_HOST: ${{ secrets.EC2_HOST }}
        EC2_USER: ${{ secrets.EC2_USER }}
      run: |
        ssh -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new \
          "$EC2_USER@$EC2_HOST" << 'REMOTE_SCRIPT'
        
        # Download and run the monitor script
        SCRIPT_URL="https://raw.githubusercontent.com/${{ github.repository }}/main/scripts/magicrugs_monitor.sh"
        TEMP_SCRIPT="/tmp/magicrugs_monitor_$RANDOM.sh"
        
        # Download the script
        curl -sSf "$SCRIPT_URL" -o "$TEMP_SCRIPT"
        
        if [ ! -f "$TEMP_SCRIPT" ]; then
          echo "❌ Failed to download script from $SCRIPT_URL"
          exit 1
        fi
        
        # Fix line endings (CRLF to LF)
        sed -i 's/\r$//' "$TEMP_SCRIPT"
        
        # Make executable
        chmod +x "$TEMP_SCRIPT"
        
        # Run the script
        "$TEMP_SCRIPT"
        
        # Capture exit code
        EXIT_CODE=$?
        
        # Cleanup
        rm -f "$TEMP_SCRIPT"
        
        exit $EXIT_CODE
        REMOTE_SCRIPT

    - name: 📊 Fetch reports from EC2
      env:
        EC2_HOST: ${{ secrets.EC2_HOST }}
        EC2_USER: ${{ secrets.EC2_USER }}
      run: |
        mkdir -p reports
        
        # Get the latest report from EC2
        scp -o ConnectTimeout=10 \
          "$EC2_USER@$EC2_HOST:/var/log/magicrugs-monitor/monitor_report_*.txt" \
          reports/ 2>/dev/null || echo "⚠️ No reports found yet"
        
        # List what was fetched
        if [ -f reports/monitor_report_*.txt ]; then
          echo "✅ Latest report:"
          ls -lh reports/monitor_report_*.txt | tail -1
        fi

    - name: 📝 Commit reports to repository
      run: |
        git config --global user.name "GitHub Actions"
        git config --global user.email "actions@github.com"
        
        # Add reports directory
        git add reports/ || true
        
        # Check if there are changes
        if git diff --cached --quiet; then
          echo "ℹ️ No new reports to commit"
        else
          git commit -m "🔄 Auto: Monitor report $(date +'%Y-%m-%d %H:%M:%S')" || true
          git push || true
        fi
      continue-on-error: true

    - name: 📧 Send Slack notification (optional)
      if: always()
      env:
        SLACK_WEBHOOK: ${{ secrets.SLACK_WEBHOOK_URL }}
        JOB_STATUS: ${{ job.status }}
      run: |
        if [ -z "$SLACK_WEBHOOK" ]; then
          echo "⚠️ Slack webhook not configured"
          exit 0
        fi
        
        # Get latest report summary
        LATEST_REPORT=$(ls -t reports/monitor_report_*.txt 2>/dev/null | head -1)
        
        if [ -f "$LATEST_REPORT" ]; then
          SUMMARY=$(head -20 "$LATEST_REPORT" | tail -15)
          STATUS="✅ Success - Report Generated"
        else
          SUMMARY="No report generated"
          STATUS="⚠️ Completed with warnings"
        fi
        
        curl -X POST "$SLACK_WEBHOOK" \
          -H 'Content-Type: application/json' \
          -d "{
            \"text\": \"🔍 Magicrugs Monitor Report\",
            \"blocks\": [
              {
                \"type\": \"header\",
                \"text\": {
                  \"type\": \"plain_text\",
                  \"text\": \"Magicrugs Traffic Monitor\"
                }
              },
              {
                \"type\": \"section\",
                \"text\": {
                  \"type\": \"mrkdwn\",
                  \"text\": \"*Status:* $STATUS\n*Timestamp:* $(date)\n*Report:* Available in GitHub\"
                }
              }
            ]
          }" || true

    - name: 📋 Generate summary
      if: always()
      run: |
        echo "## 🔍 Monitor Execution Summary" >> $GITHUB_STEP_SUMMARY
        echo "" >> $GITHUB_STEP_SUMMARY
        echo "**Status:** ${{ job.status }}" >> $GITHUB_STEP_SUMMARY
        echo "**Timestamp:** $(date)" >> $GITHUB_STEP_SUMMARY
        echo "" >> $GITHUB_STEP_SUMMARY
        
        if [ -f reports/monitor_report_*.txt ]; then
          echo "### Latest Report" >> $GITHUB_STEP_SUMMARY
          echo '```' >> $GITHUB_STEP_SUMMARY
          head -30 reports/monitor_report_*.txt | tail -25 >> $GITHUB_STEP_SUMMARY 2>/dev/null || true
          echo '```' >> $GITHUB_STEP_SUMMARY
        fi