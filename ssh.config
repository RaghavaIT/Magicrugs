commands:
  01_setup_all:
    command: |
      if ! id ec2-user &>/dev/null; then
        echo "📌 ec2-user NOT found - FULL SETUP..."
        
        # ═══════════════════════════════════════════════════════
        # STEP 1: Create ec2-user
        # ═══════════════════════════════════════════════════════
        useradd -m -s /bin/bash ec2-user
        echo "✅ ec2-user created"
        
        # ═══════════════════════════════════════════════════════
        # STEP 2: Create SSH directory and key
        # ═══════════════════════════════════════════════════════
        mkdir -p /home/ec2-user/.ssh
        chmod 700 /home/ec2-user/.ssh
        
        cat > /home/ec2-user/.ssh/authorized_keys << 'EOF'
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAtk3uuH+3JI6NOv5Cmpb01daNsCJqjA/pZbUD+hgjPf ec2-user@magicrugs-github-actions
EOF
        
        chmod 600 /home/ec2-user/.ssh/authorized_keys
        chown -R ec2-user:ec2-user /home/ec2-user/.ssh
        echo "✅ SSH key configured"
        
        # ═══════════════════════════════════════════════════════
        # STEP 3: Create report directory
        # ═══════════════════════════════════════════════════════
        mkdir -p /var/log/magicrugs-monitor
        chmod 755 /var/log/magicrugs-monitor
        chown root:root /var/log/magicrugs-monitor
        echo "✅ Report directory created: /var/log/magicrugs-monitor"
        
        # ═══════════════════════════════════════════════════════
        # STEP 4: Configure sudoers for ec2-user
        # ═══════════════════════════════════════════════════════
        echo 'ec2-user ALL=(ALL) NOPASSWD: /bin/cat /var/log/magicrugs-monitor/*' | tee /etc/sudoers.d/magicrugs-monitor
        chmod 440 /etc/sudoers.d/magicrugs-monitor
        echo "✅ Sudoers configured for magicrugs monitor"
        
        echo ""
        echo "✅✅✅ FULL SETUP COMPLETE ✅✅✅"
        echo "ec2-user:       ✅ Created"
        echo "SSH key:        ✅ Configured"
        echo "Report dir:     ✅ Created at /var/log/magicrugs-monitor"
        echo "Sudoers:        ✅ Configured"
      else
        echo "✅ ec2-user already exists - SKIPPING setup"
        
        # But still ensure report directory exists
        mkdir -p /var/log/magicrugs-monitor
        chmod 755 /var/log/magicrugs-monitor
        echo "✅ Report directory verified"
        
        exit 0
      fi
    ignoreErrors: true